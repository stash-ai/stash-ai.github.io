# NEET JEEnius landing: example environment variables
#
# Static HTML does not load .env by itself. Use this file to:
# - Document secrets for your team
# - Feed a deploy/build step that writes firebase-config.js, posthog-config.js, google-tag-config.js
#
# Copy to .env locally (never commit .env). See *.example.js in this folder for the JS shape.

# Firebase (window.__FIREBASE_CONFIG__ → firebase-config.js)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# PostHog (window.__POSTHOG_CONFIG__ → posthog-config.js)
POSTHOG_API_KEY=
POSTHOG_API_HOST=https://us.i.posthog.com

# Google Ads / gtag conversion ID (window.__GOOGLE_TAG_CONFIG__ → google-tag-config.js), e.g. AW-17763182742
GOOGLE_TAG_ID=
